---
import "../../styles/global.css"
import Navigation from "../../components/Navigation.astro"
import Footer from "../../components/Footer.astro"
import ComparisonLayout from "../../components/ComparisonLayout.astro"
import TableOfContents from "../../components/TableOfContents.astro"
import ComparisonHero from "../../components/ComparisonHero.astro"
import ProConsTable from "../../components/ProConsTable.astro"
import ComparisonTable from "../../components/ComparisonTable.astro"
import FeatureSection from "../../components/FeatureSection.astro"
import ComparisonCTA from "../../components/ComparisonCTA.astro"
import emailEditorImage from "../../assets/screenshots/email_editor.png"
import contactProfileImage from "../../assets/screenshots/contact_profile.png"
import dashboardImage from "../../assets/screenshots/dashboard.png"

// Table of Contents items
const tocItems = [
  { id: "overview", label: "Overview" },
  { id: "quick-comparison", label: "Quick Comparison" },
  { id: "pricing", label: "Pricing & Cost Comparison" },
  { id: "email-builder", label: "Email Builder" },
  { id: "campaigns", label: "Campaigns" },
  { id: "contact-management", label: "Contact Management & Segmentation" },
  { id: "email-sending", label: "Email Sending & Deliverability" },
  { id: "analytics", label: "Analytics & Reporting" },
  { id: "automations", label: "Automations" },
  { id: "custom-events", label: "Custom Events & Goals" },
  { id: "multi-tenancy", label: "Multi-tenancy & Agency" },
  { id: "developer-api", label: "Developer Experience & API" },
  { id: "blog", label: "Blog" },
  { id: "use-cases", label: "Use Cases" },
  { id: "why-switch", label: "Why Choose Notifuse" },
  { id: "faq", label: "FAQ" },
]

// Pros & Cons Summary Data
const proConsRows = [
  {
    label: "Starting Price",
    notifuse: "Free (self-hosted)",
    competitor: "Free tier: 300 emails/day",
  },
  {
    label: "License",
    notifuse: "AGPL-3.0 (Open-source)",
    competitor: "Proprietary (Closed-source)",
  },
  {
    label: "Deployment",
    notifuse: "Self-hosted",
    competitor: "Cloud-only SaaS",
  },
  {
    label: "Contact Limits",
    notifuse: "Unlimited",
    competitor: "100K free, 500K Starter, 2M Pro",
  },
  {
    label: "Email Volume",
    notifuse: "Unlimited (ESP-dependent)",
    competitor: "300/day free, then plan-based",
  },
  {
    label: "Feature Access",
    notifuse: "All features included",
    competitor: "Gated by tier ($18-$499+/mo)",
  },
  {
    label: "Data Ownership",
    notifuse: "Full (your infrastructure)",
    competitor: "Brevo-hosted (EU data center)",
  },
]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>
      Notifuse vs Brevo: Open-Source Self-Hosted vs SaaS Email Platform (2026)
    </title>
    <meta
      name="description"
      content="Compare Notifuse (open-source, self-hosted) and Brevo (SaaS, multi-channel). Features, pricing, automations, and which is better for your email needs. Formerly Sendinblue."
    />
    <link
      rel="canonical"
      href="https://notifuse.com/compare/notifuse-vs-brevo"
    />
    <meta name="theme-color" content="#FF6B35" />
    <meta
      name="keywords"
      content="Notifuse vs Brevo, Brevo alternative, Sendinblue alternative, self-hosted email platform, open-source email marketing, Brevo pricing"
    />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content="https://notifuse.com/compare/notifuse-vs-brevo"
    />
    <meta
      property="og:title"
      content="Notifuse vs Brevo: Open-Source Self-Hosted vs SaaS Email Platform"
    />
    <meta
      property="og:description"
      content="Compare Notifuse (open-source, self-hosted) and Brevo (SaaS, multi-channel). All features included vs tier-gated pricing starting at $499/mo."
    />
    <meta property="og:image" content="https://notifuse.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Notifuse" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Notifuse vs Brevo: Open-Source Email Platform Comparison"
    />
    <meta
      name="twitter:description"
      content="Compare Notifuse (open-source, self-hosted) vs Brevo (SaaS). All features included vs $499/mo for advanced features."
    />
    <meta name="twitter:image" content="https://notifuse.com/og-image.png" />
    <meta name="twitter:site" content="@notifuse" />
    <meta name="twitter:creator" content="@notifuse" />

    <script
      defer
      data-domain="notifuse.com"
      src="https://plausible.notifuse.com/js/script.js"></script>

    <!-- Staminads Analytics -->
    <link rel="dns-prefetch" href="https://prod.staminads.com" />
    <link rel="preconnect" href="https://prod.staminads.com" />
    <script is:inline>
    window.StaminadsConfig = {
      workspace_id: 'notifuse',
      endpoint: 'https://prod.staminads.com'
    };
    </script>
    <script async src="/staminads_5.0.0.min.js"></script>
  </head>

  <body class="bg-white-98">
    <div class="container relative border-r border-l border-gray-200">
      <!-- Navigation -->
      <Navigation />

      <!-- Hero Section -->
      <ComparisonHero
        competitor="Brevo"
        description="Notifuse is open-source and self-hosted with all features included. Brevo (formerly Sendinblue) is a multi-channel SaaS that gates key features behind $18-$499+/mo tiers. Choose Notifuse for full data ownership and no per-contact pricing."
      />

      <!-- Main Comparison Layout -->
      <ComparisonLayout
        title="Notifuse vs Brevo"
        description="Detailed comparison of features, pricing, and use cases"
      >
        <!-- Table of Contents (Sidebar) -->
        <TableOfContents slot="toc" items={tocItems} />

        <!-- Overview Section -->
        <FeatureSection id="overview" title="Overview">
          <div
            class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl mb-12"
          >
            <div
              class="bg-gradient-to-br from-orange-50 to-pink-50 rounded-xl p-12"
            >
              <h3 class="text-xl font-bold text-slate-900 mb-8">
                The Two Core Differences
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                  <div class="flex items-start mb-4">
                    <span class="text-2xl font-bold text-primary mr-3">1.</span>
                    <h4 class="font-semibold text-slate-900 mt-1">
                      Open-Source vs Proprietary SaaS
                    </h4>
                  </div>
                  <p class="text-sm text-gray-700 mb-3">
                    <strong class="text-primary">Notifuse:</strong> AGPL-3.0 open-source,
                    self-hosted. Full control over your code and data.
                  </p>
                  <p class="text-sm text-gray-500">
                    <strong>Brevo:</strong> Proprietary closed-source SaaS with tiered
                    pricing. Your data lives on Brevo's servers.
                  </p>
                </div>
                <div>
                  <div class="flex items-start mb-4">
                    <span class="text-2xl font-bold text-primary mr-3">2.</span>
                    <h4 class="font-semibold text-slate-900 mt-1">
                      All Features Included vs Tier-Gated
                    </h4>
                  </div>
                  <p class="text-sm text-gray-700 mb-3">
                    <strong class="text-primary">Notifuse:</strong> Every feature available
                    from day one. No per-contact fees.
                  </p>
                  <p class="text-sm text-gray-500">
                    <strong>Brevo:</strong> Key features locked behind Standard ($18/mo),
                    Professional ($499/mo), and Enterprise tiers.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Critical: Feature Gating Callout -->
          <div
            class="bg-gradient-to-br from-gray-200 via-gray-200 to-red-400 p-px rounded-xl mb-8"
          >
            <div
              class="bg-gradient-to-br from-red-50 to-orange-50 rounded-xl p-8"
            >
              <div class="flex items-start">
                <svg
                  class="w-8 h-8 text-red-500 mr-4 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                  ></path>
                </svg>
                <div>
                  <h4 class="font-bold text-slate-900 mb-2 text-lg">
                    Brevo's Feature Gating
                  </h4>
                  <p class="text-gray-700 text-sm mb-3">
                    Many features you'd expect to be standard require paid upgrades on Brevo:
                  </p>
                  <ul class="space-y-2 text-sm text-gray-700">
                    <li class="flex items-start">
                      <svg
                        class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                          clip-rule="evenodd"></path>
                      </svg>
                      <span
                        ><strong>Standard ($18/mo):</strong> Marketing automation, A/B testing,
                        advanced reports, send time optimization</span
                      >
                    </li>
                    <li class="flex items-start">
                      <svg
                        class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                          clip-rule="evenodd"></path>
                      </svg>
                      <span
                        ><strong>Professional ($499/mo):</strong> WhatsApp, push notifications,
                        contact scoring, AI segmentation, phone support</span
                      >
                    </li>
                    <li class="flex items-start">
                      <svg
                        class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                          clip-rule="evenodd"></path>
                      </svg>
                      <span
                        ><strong>Enterprise (custom):</strong> CDP, loyalty programs, custom
                        objects, dedicated IP, SSO</span
                      >
                    </li>
                    <li class="flex items-start">
                      <svg
                        class="w-5 h-5 text-green-600 mr-2 flex-shrink-0 mt-0.5"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                          clip-rule="evenodd"></path>
                      </svg>
                      <span
                        ><strong class="text-primary">Notifuse:</strong> All features included
                        at $0 software cost</span
                      >
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <p class="text-gray-600 mb-6">
            <span class="font-semibold text-slate-900">Brevo</span> (formerly Sendinblue) is
            a multi-channel SaaS marketing platform offering email, SMS, WhatsApp, CRM,
            and live chat. It's feature-rich but gates key capabilities behind expensive
            tiers and charges per contact.
          </p>
          <p class="text-gray-600 mb-6">
            <span class="font-semibold text-slate-900">Notifuse</span> is an open-source,
            self-hosted email platform with a visual MJML builder, advanced segmentation,
            automations, multi-tenancy, and flexible ESP connections. <strong
              >All features included</strong
            > from day one—no tier-based pricing, no per-contact fees.
          </p>
        </FeatureSection>

        <!-- Quick Comparison Table -->
        <FeatureSection id="quick-comparison" title="Quick Comparison" gradient>
          <ProConsTable competitor="Brevo" rows={proConsRows} />
          <ComparisonCTA compact />
        </FeatureSection>

        <!-- Pricing & Cost Comparison -->
        <FeatureSection id="pricing" title="Pricing & Cost Comparison" gradient>
          <p class="text-gray-600 mb-6">
            Brevo's tiered pricing adds up quickly. Notifuse is free software—you only pay for hosting and your ESP.
          </p>

          <div
            class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl mb-8"
          >
            <div
              class="bg-gradient-to-br from-white to-orange-50 rounded-xl p-8"
            >
              <h4 class="font-bold text-slate-900 mb-4 text-lg text-center">
                Cost at Scale: 100K Emails/Month
              </h4>
              <p class="text-gray-700 text-sm text-center mb-6">
                Compare the real cost when you need automation, A/B testing, and advanced features.
              </p>

              <!-- Cost Comparison -->
              <div class="mb-6">
                <h5
                  class="text-sm font-semibold text-slate-900 text-center mb-3"
                >
                  With Automations & Advanced Features
                </h5>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
                  <div
                    class="border border-primary bg-orange-50 rounded-lg p-4"
                  >
                    <div class="text-xs text-gray-500 mb-1">Notifuse + SES</div>
                    <div class="text-2xl font-bold text-primary">~$25-40</div>
                    <div class="text-xs text-gray-600">All features included</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-4">
                    <div class="text-xs text-gray-500 mb-1">Brevo Standard</div>
                    <div class="text-2xl font-bold text-gray-700">$18+</div>
                    <div class="text-xs text-gray-600">Basic automation only</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-4">
                    <div class="text-xs text-gray-500 mb-1">Brevo Professional</div>
                    <div class="text-2xl font-bold text-gray-700">$499+</div>
                    <div class="text-xs text-gray-600">Full feature access</div>
                  </div>
                </div>
              </div>

              <!-- Brevo Tier Breakdown -->
              <div class="mb-6">
                <h5
                  class="text-sm font-semibold text-slate-900 text-center mb-3"
                >
                  Brevo Plan Breakdown
                </h5>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 text-center">
                  <div class="border border-gray-200 rounded-lg p-3">
                    <div class="text-xs font-semibold text-gray-700 mb-1">Free</div>
                    <div class="text-sm text-gray-600">300 emails/day</div>
                    <div class="text-xs text-gray-400">100K contacts</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-3">
                    <div class="text-xs font-semibold text-gray-700 mb-1">Starter $9/mo</div>
                    <div class="text-sm text-gray-600">5K emails/mo</div>
                    <div class="text-xs text-gray-400">No automation</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-3">
                    <div class="text-xs font-semibold text-gray-700 mb-1">Standard $18/mo</div>
                    <div class="text-sm text-gray-600">Automation + A/B</div>
                    <div class="text-xs text-gray-400">No WhatsApp/push</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-3">
                    <div class="text-xs font-semibold text-gray-700 mb-1">Pro $499/mo</div>
                    <div class="text-sm text-gray-600">All channels</div>
                    <div class="text-xs text-gray-400">AI + scoring</div>
                  </div>
                </div>
              </div>

              <p class="text-xs text-gray-500 text-center mb-2">
                Notifuse total: $0 (software) + $10 (Amazon SES for 100K) + $15-30 (hosting) = ~$25-40/month for all features
              </p>
              <p class="text-[10px] text-gray-400 text-center">
                Pricing as of March 2026
              </p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div
              class="border-2 border-primary rounded-xl p-8 relative overflow-hidden"
            >
              <div
                class="absolute top-0 right-0 bg-primary text-white px-3 py-1 text-xs font-semibold"
              >
                Best Value
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Notifuse</h3>
              <div class="text-4xl font-bold text-primary mb-2">$0</div>
              <p class="text-sm text-gray-600 mb-4">
                Software cost (self-hosted)
              </p>

              <div class="text-sm text-gray-700 mb-6">
                <strong>+ Hosting:</strong> ~$15-30/month<br />
                <strong>+ Amazon SES:</strong> ~$10/month (100k emails)
                <div class="mt-2 pt-2 border-t border-gray-200">
                  <strong>Total: ~$25-40/month</strong> for unlimited features
                </div>
              </div>

              <ul class="space-y-2 text-sm">
                <li>&#10003; Unlimited contacts (no per-contact fees)</li>
                <li>&#10003; All features included from day one</li>
                <li>&#10003; Open-source code</li>
                <li>&#10003; ESP flexibility</li>
                <li>&#10003; Full data ownership</li>
              </ul>
            </div>

            <div class="border border-gray-200 rounded-xl p-8">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Brevo</h3>
              <div class="text-sm text-gray-600 mb-4">Tiered SaaS pricing</div>

              <div class="space-y-3 mb-6 text-sm">
                <div>
                  <strong>Free:</strong> 300 emails/day, 100K contacts<br />
                  <span class="text-gray-500">No automation, Brevo branding</span>
                </div>
                <div>
                  <strong>Starter:</strong> From $9/month<br />
                  <span class="text-gray-500">5K-100K emails, no automation</span>
                </div>
                <div>
                  <strong>Standard:</strong> From $18/month<br />
                  <span class="text-gray-500">Automation, A/B testing</span>
                </div>
                <div>
                  <strong>Professional:</strong> From $499/month<br />
                  <span class="text-gray-500">WhatsApp, push, AI, scoring</span>
                </div>
                <div class="text-xs text-gray-500">
                  + Enterprise for CDP, loyalty, SSO
                </div>
              </div>

              <ul class="space-y-2 text-sm text-gray-500">
                <li>&#10007; Per-contact pricing at scale</li>
                <li>&#10007; Features gated by tier</li>
                <li>&#10007; Closed-source</li>
                <li>&#10007; Cloud-only</li>
                <li>&#10007; Data on Brevo's servers</li>
              </ul>
            </div>
          </div>

          <ComparisonCTA
            title="Ready to save on email costs?"
            description="Get all features for the cost of hosting + ESP. No per-contact fees, no tier gates."
            compact
          />
        </FeatureSection>

        <!-- Email Builder -->
        <FeatureSection id="email-builder" title="Email Builder">
          <p class="text-gray-600 mb-6">
            Both platforms offer visual email editors, but with different approaches to code access and templating.
          </p>

          <ComparisonTable
            title="Email Builder Comparison"
            competitorName="Brevo"
            features={[
              {
                feature: "Visual Email Builder",
                notifuse:
                  '<a href="https://documentation.mjml.io/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline font-semibold">MJML</a>-based - visual drag-and-drop & code editor, guarantees mobile-responsive & compatible with all email clients',
                competitor: "Drag-and-drop editor (no code access)",
              },
              {
                feature: "MJML Code Editor",
                notifuse: "Direct MJML code editing alongside visual drag-and-drop",
                competitor: false,
                description: "Switch between visual and code modes",
              },
              {
                feature: "HTML Editor",
                notifuse: "Via MJML code mode",
                competitor: "Raw HTML editor available",
              },
              {
                feature: "Templating Engine",
                notifuse:
                  '<a href="https://shopify.github.io/liquid/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline font-semibold">Liquid</a>',
                competitor: "Brevo's proprietary template language",
                description: "Dynamic variables for personalization",
              },
              {
                feature: "Built-in File Manager",
                notifuse: "S3-compatible storage with CDN support",
                competitor: "Basic image uploads",
              },
              {
                feature: "Template Library",
                notifuse: "Coming soon",
                competitor: "50+ pre-built templates",
              },
              {
                feature: "AI Content Generation",
                notifuse: "Via Anthropic (Claude) integration",
                competitor: "Built-in AI (subject lines + body)",
              },
              {
                feature: "Support for Test Data",
                notifuse: true,
                competitor: false,
                description: "Preview emails with sample contact data",
              },
            ]}
          />

          <!-- Email Editor Screenshot -->
          <div class="my-8">
            <div
              class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl"
            >
              <div class="rounded-xl overflow-hidden">
                <img
                  src={emailEditorImage.src}
                  alt="Notifuse MJML Email Builder"
                  class="w-full h-auto"
                />
              </div>
            </div>
            <p class="text-center text-xs text-gray-500 mt-2">
              Notifuse UI - MJML Visual Email Builder with Code Editor
            </p>
          </div>

          <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
            <h4 class="font-semibold text-slate-900 mb-2">Why MJML Matters</h4>
            <p class="text-gray-700 text-sm">
              Notifuse uses MJML, the industry-standard framework for responsive emails.
              Unlike Brevo's proprietary editor, MJML is open-source and guarantees
              compatibility across all email clients. You also get direct code access
              for full customization—something Brevo's drag-and-drop editor doesn't offer.
            </p>
          </div>
        </FeatureSection>

        <!-- Campaigns -->
        <FeatureSection id="campaigns" title="Campaigns">
          <p class="text-gray-600 mb-6">
            Both platforms support broadcast campaigns. Brevo adds SMS and WhatsApp
            but locks them behind the $499/mo Professional plan.
          </p>

          <ComparisonTable
            title="Campaign Features"
            competitorName="Brevo"
            features={[
              {
                feature: "Broadcast Campaigns",
                notifuse: true,
                competitor: true,
              },
              {
                feature: "A/B Testing",
                notifuse: "Auto winner selection (open/click rate)",
                competitor: "Yes (Standard plan, $18/mo+)",
              },
              {
                feature: "UTM Tracking",
                notifuse: true,
                competitor: true,
              },
              {
                feature: "Schedule Campaigns",
                notifuse: true,
                competitor: true,
              },
              {
                feature: "AI Send Time Optimization",
                notifuse: false,
                competitor: "Professional plan ($499/mo)",
