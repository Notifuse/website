---
import "../../../styles/global.css"
import Navigation from "../../../components/Navigation.astro"
import Footer from "../../../components/Footer.astro"
import GtagHead from "../../../components/GtagHead.astro"
import CookieConsent from "../../../components/CookieConsent.astro"

// Import competitor logos
import listmonkLogo from "../../../assets/competitors/listmonk-logo.png"
import resendLogo from "../../../assets/competitors/resend-logo.png"
import mailchimpLogo from "../../../assets/competitors/mailchimp-logo.png"
import loopsLogo from "../../../assets/competitors/loops-logo.png"
import customerioLogo from "../../../assets/competitors/customerio-logo.png"
import klaviyoLogo from "../../../assets/competitors/klaviyo-logo.png"
import mailerliteLogo from "../../../assets/competitors/mailerlite-logo.png"
import brevoLogo from "../../../assets/competitors/brevo-logo.png"
import mauticLogo from "../../../assets/competitors/mautic-logo.png"

// Comparison alternatives data
const alternatives = [
  {
    name: "Listmonk",
    slug: "listmonk",
    description: "Gestionnaire de listes auto-hébergé",
    logo: listmonkLogo,
    available: true,
  },
  {
    name: "Resend",
    slug: "resend",
    description: "API email pour développeurs",
    logo: resendLogo,
    available: true,
  },
  {
    name: "Mailchimp",
    slug: "mailchimp",
    description: "Plateforme d'email marketing populaire",
    logo: mailchimpLogo,
    available: true,
  },
  {
    name: "Loops",
    slug: "loops",
    description: "Plateforme email pour SaaS",
    logo: loopsLogo,
    available: true,
  },
  {
    name: "Customer.io",
    slug: "customerio",
    description: "Plateforme de messagerie automatisée",
    logo: customerioLogo,
    available: true,
  },
  {
    name: "Klaviyo",
    slug: "klaviyo",
    description: "Marketing automation pour l'e-commerce",
    logo: klaviyoLogo,
    available: true,
  },
  {
    name: "MailerLite",
    slug: "mailerlite",
    description: "Plateforme d'email marketing",
    logo: mailerliteLogo,
    available: true,
  },
  {
    name: "Brevo",
    slug: "brevo",
    description: "Plateforme de marketing digital",
    logo: brevoLogo,
    available: true,
  },
  {
    name: "Mautic",
    slug: "mautic",
    description: "Plateforme de marketing automation open-source",
    logo: mauticLogo,
    available: true,
  },
]
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>
      Comparaison des alternatives à Notifuse — vs Listmonk, Mailchimp, Brevo...
    </title>
    <meta
      name="description"
      content="Comparez Notifuse avec les plateformes email populaires comme Listmonk, Mailchimp, Brevo, SendGrid, Mailgun et d'autres. Trouvez la meilleure solution email pour vos besoins — Cloud ou auto-hébergé."
    />
    <link rel="canonical" href="https://notifuse.com/fr/compare" />
    <meta name="theme-color" content="#7763F1" />
    <meta
      name="keywords"
      content="alternatives Notifuse, comparaison plateforme email, alternative Listmonk, alternative Mailchimp, email auto-hébergé, newsletter open source"
    />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://notifuse.com/fr/compare" />
    <meta property="og:title" content="Comparaison des alternatives à Notifuse" />
    <meta
      property="og:description"
      content="Comparez Notifuse avec les plateformes email populaires comme Listmonk, Mailchimp, Brevo, SendGrid et d'autres."
    />
    <meta property="og:image" content="https://notifuse.com/og-image.png" />
    <meta property="og:site_name" content="Notifuse" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Comparaison des alternatives à Notifuse" />
    <meta
      name="twitter:description"
      content="Comparez Notifuse avec les plateformes email populaires."
    />
    <meta name="twitter:image" content="https://notifuse.com/og-image.png" />
    <meta name="twitter:site" content="@notifuse" />

    <GtagHead />

    <script
      defer
      data-domain="notifuse.com"
      src="https://plausible.notifuse.com/js/script.js"></script>

    <!-- Staminads Analytics -->
    <link rel="dns-prefetch" href="https://prod.staminads.com" />
    <link rel="preconnect" href="https://prod.staminads.com" />
    <script is:inline>
    window.StaminadsConfig = {
      workspace_id: 'notifuse',
      endpoint: 'https://prod.staminads.com'
    };
    </script>
    <script async src="/staminads_5.0.0.min.js"></script>
  </head>

  <body class="bg-white-98">
    <div class="container relative border-r border-l border-gray-200">
      <!-- Navigation -->
      <Navigation />

      <!-- Hero Section -->
      <section class="border-b border-gray-200">
        <div class="px-4 lg:px-8 py-20">
          <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
              Comparez
              <span
                class="bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent"
              >
                Notifuse
              </span>
              <span class="text-slate-900"> avec les alternatives</span>
            </h1>
            <p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
              Découvrez comment Notifuse se compare aux autres plateformes email.
              Auto-hébergé, cloud, open-source ou propriétaire — trouvez la
              comparaison adaptée à vos besoins.
            </p>

            <!-- Newsletter Signup CTA -->
            <div class="max-w-md mx-auto">
              <p class="text-sm text-gray-600 mb-4">
                Soyez informé des nouvelles fonctionnalités
              </p>
              <form
                id="newsletter-form-hero"
                class="flex flex-col sm:flex-row gap-3"
              >
                <input
                  id="email-input-hero"
                  type="email"
                  placeholder="Votre adresse email"
                  class="flex-1 px-4 py-2.5 rounded-md border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                  required
                />
                <button
                  id="subscribe-btn-hero"
                  type="submit"
                  class="bg-primary text-white px-6 py-2.5 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  S'abonner
                </button>
              </form>
              <div id="form-message-hero" class="mt-3 text-sm"></div>
              <p class="text-xs text-gray-500 mt-2">
                Pas de spam. Désabonnement possible à tout moment.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Comparison Grid -->
      <section class="border-b border-gray-200">
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-t border-gray-200"
        >
          {
            alternatives.map((alt, index) => (
              <a
                href={alt.available ? `/fr/compare/notifuse-vs-${alt.slug}` : "#"}
                class={`relative p-8 border-r border-b border-gray-200 transition-colors ${
                  alt.available
                    ? "hover:bg-white cursor-pointer"
                    : "cursor-not-allowed opacity-60"
                }`}
              >
                {!alt.available && (
                  <div class="absolute top-4 right-4">
                    <span class="text-xs bg-gray-600 text-white px-2 py-1">
                      Bientôt disponible
                    </span>
                  </div>
                )}

                <div class="mb-6">
                  <img
                    src={alt.logo.src}
                    alt={`Logo ${alt.name}`}
                    class="h-8 mb-4"
                  />
                  <h3 class="text-lg font-bold text-slate-900 mb-2">
                    Notifuse vs {alt.name}
                  </h3>
                </div>

                <p class="text-sm text-gray-600 mb-6">{alt.description}</p>

                {alt.available ? (
                  <div class="flex items-center text-primary text-sm font-semibold">
                    Voir la comparaison
                    <svg
                      class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </div>
                ) : (
                  <div class="text-sm text-gray-400">
                    Comparaison bientôt disponible
                  </div>
                )}
              </a>
            ))
          }
        </div>
      </section>

      <!-- Why Compare Section -->
      <section class="border-b border-gray-200">
        <div class="px-4 lg:px-8 py-16">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-2xl font-bold text-slate-900 mb-8 text-center">
              Pourquoi comparer les plateformes email ?
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="flex items-start">
                <div
                  class="w-12 h-12 bg-primary/10 flex items-center justify-center mr-4 flex-shrink-0"
                >
                  <svg
                    class="w-6 h-6 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 mb-2">
                    Prenez des décisions éclairées
                  </h3>
                  <p class="text-sm text-gray-600">
                    Comprenez les différences en termes de fonctionnalités, de
                    tarifs et de capacités avant de choisir votre plateforme email.
                  </p>
                </div>
              </div>

              <div class="flex items-start">
                <div
                  class="w-12 h-12 bg-primary/10 flex items-center justify-center mr-4 flex-shrink-0"
                >
                  <svg
                    class="w-6 h-6 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 mb-2">Économisez</h3>
                  <p class="text-sm text-gray-600">
                    Découvrez comment Notifuse Cloud se compare aux plateformes
                    email coûteuses et calculez vos économies.
                  </p>
                </div>
              </div>

              <div class="flex items-start">
                <div
                  class="w-12 h-12 bg-primary/10 flex items-center justify-center mr-4 flex-shrink-0"
                >
                  <svg
                    class="w-6 h-6 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 mb-2">
                    Trouvez les bonnes fonctionnalités
                  </h3>
                  <p class="text-sm text-gray-600">
                    Découvrez quelle plateforme propose les éditeurs visuels, les
                    API, la segmentation et les fonctionnalités d'automatisation
                    dont vous avez besoin.
                  </p>
                </div>
              </div>

              <div class="flex items-start">
                <div
                  class="w-12 h-12 bg-primary/10 flex items-center justify-center mr-4 flex-shrink-0"
                >
                  <svg
                    class="w-6 h-6 text-primary"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 mb-2">
                    Gardez le contrôle de vos données
                  </h3>
                  <p class="text-sm text-gray-600">
                    Conservez la pleine propriété de vos données avec Notifuse
                    Cloud ou en auto-hébergement. Export complet de la base de
                    données sur demande.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="border-b border-gray-200">
        <div class="px-4 lg:px-8 py-16">
          <div
            class="max-w-3xl mx-auto bg-gradient-to-br from-gray-50 to-orange-50 border border-gray-200 rounded-xl p-8 text-center"
          >
            <h2 class="text-2xl font-bold text-slate-900 mb-4">
              Prêt à essayer Notifuse ?
            </h2>
            <p class="text-gray-600 mb-6">
              Découvrez la plateforme email moderne avec des fonctionnalités
              avancées pour les développeurs et les marketeurs. Commencez avec
              le Cloud ou en auto-hébergement.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="https://cloud.notifuse.com/signup"
                class="bg-primary text-white px-6 py-3 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors"
              >
                Essai gratuit
              </a>
              <a
                href="https://demo.notifuse.com/console/signin?email=demo@notifuse.com"
                class="border border-gray-200 bg-white text-gray-700 px-6 py-3 rounded-md text-base font-semibold hover:bg-gray-50 transition-colors"
              >
                Démo en ligne
              </a>
              <a
                href="https://docs.notifuse.com/installation"
                class="border border-gray-200 bg-white text-gray-700 px-6 py-3 rounded-md text-base font-semibold hover:bg-gray-50 transition-colors"
              >
                Auto-hébergé
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <Footer />
    </div>

    <CookieConsent />

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById(
          "newsletter-form-hero"
        ) as HTMLFormElement
        const emailInput = document.getElementById(
          "email-input-hero"
        ) as HTMLInputElement
        const submitBtn = document.getElementById(
          "subscribe-btn-hero"
        ) as HTMLButtonElement
        const messageDiv = document.getElementById(
          "form-message-hero"
        ) as HTMLDivElement

        function showMessage(message: string, isError: boolean = false): void {
          if (messageDiv) {
            messageDiv.textContent = message
            messageDiv.className = `mt-3 text-sm ${isError ? "text-red-400" : "text-green-400"}`
          }
        }

        function setLoading(loading: boolean): void {
          if (submitBtn) {
            submitBtn.disabled = loading
            submitBtn.textContent = loading
              ? "Inscription en cours..."
              : "S'abonner"
          }
        }

        if (form && emailInput && submitBtn && messageDiv) {
          form.addEventListener("submit", async function (e) {
            e.preventDefault()

            const email = emailInput.value.trim()
            if (!email) {
              showMessage("Veuillez entrer une adresse email valide.", true)
              return
            }

            setLoading(true)
            messageDiv.textContent = ""

            try {
              const response = await fetch(
                "https://v3.notifuse.com/subscribe",
                {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                  },
                  body: JSON.stringify({
                    workspace_id: "notifuse",
                    contact: {
                      email: email,
                    },
                    list_ids: ["newsletter"],
                  }),
                }
              )

              if (response.ok) {
                const data = await response.json()
                if (data.success) {
                  showMessage(
                    "Inscription réussie ! Vérifiez votre email pour la confirmation."
                  )
                  emailInput.value = ""
                } else {
                  showMessage("L'inscription a échoué. Veuillez réessayer.", true)
                }
              } else {
                const errorData = await response.json().catch(() => ({}))
                const errorMessage =
                  errorData.message || "L'inscription a échoué. Veuillez réessayer."
                showMessage(errorMessage, true)
              }
            } catch (error) {
              console.error("Subscription error:", error)
              showMessage(
                "Erreur réseau. Veuillez vérifier votre connexion et réessayer.",
                true
              )
            } finally {
              setLoading(false)
            }
          })
        }
      })
    </script>
  </body>
</html>
