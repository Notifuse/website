---
import "../../../styles/global.css"
import Navigation from "../../../components/Navigation.astro"
import Footer from "../../../components/Footer.astro"
import ComparisonLayout from "../../../components/ComparisonLayout.astro"
import TableOfContents from "../../../components/TableOfContents.astro"
import ProConsTable from "../../../components/ProConsTable.astro"
import ComparisonTable from "../../../components/ComparisonTable.astro"
import FeatureSection from "../../../components/FeatureSection.astro"
import GtagHead from "../../../components/GtagHead.astro"
import CookieConsent from "../../../components/CookieConsent.astro"
import emailEditorImage from "../../../assets/screenshots/email_editor.png"
import contactProfileImage from "../../../assets/screenshots/contact_profile.png"
import dashboardImage from "../../../assets/screenshots/dashboard.png"

const tocItems = [
  { id: "apercu", label: "Aperçu" },
  { id: "comparaison-rapide", label: "Comparaison rapide" },
  { id: "tarifs", label: "Tarifs & Coûts" },
  { id: "editeur-email", label: "Éditeur d'emails" },
  { id: "campagnes", label: "Campagnes" },
  { id: "contacts", label: "Contacts & Segmentation" },
  { id: "envoi-email", label: "Envoi & Délivrabilité" },
  { id: "analytics", label: "Analytics & Reporting" },
  { id: "automations", label: "Automations" },
  { id: "evenements", label: "Événements personnalisés" },
  { id: "multi-tenant", label: "Multi-tenant & Agences" },
  { id: "api-developpeur", label: "API & Développeurs" },
  { id: "blog", label: "Blog" },
  { id: "cas-usage", label: "Cas d'usage" },
  { id: "pourquoi-changer", label: "Pourquoi changer" },
  { id: "faq", label: "FAQ" },
]

const proConsRows = [
  {
    label: "Prix de départ",
    notifuse: "Dès 19 $/mois (Cloud) · ou auto-hébergé",
    competitor: "Gratuit : 300 emails/jour",
  },
  {
    label: "Licence",
    notifuse: "Open-source (AGPL-3.0)",
    competitor: "SaaS propriétaire",
  },
  {
    label: "Déploiement",
    notifuse: "Auto-hébergé",
    competitor: "Cloud uniquement (SaaS)",
  },
  {
    label: "Limites de contacts",
    notifuse: "Illimités",
    competitor: "100K gratuit, 500K Starter, 2M Pro",
  },
  {
    label: "Volume d'emails",
    notifuse: "Illimité (dépend de l'ESP)",
    competitor: "300/jour gratuit, puis selon le plan",
  },
  {
    label: "Accès aux fonctionnalités",
    notifuse: "Toutes les fonctionnalités incluses",
    competitor: "Verrouillées par palier (18-499+ $/mois)",
  },
  {
    label: "Propriété des données",
    notifuse: "Totale (votre infrastructure)",
    competitor: "Hébergé chez Brevo (data center EU)",
  },
]
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>Notifuse vs Brevo : plateforme email open-source vs SaaS (2026)</title>
    <meta
      name="description"
      content="Comparez Notifuse (open-source, auto-hébergé) et Brevo (SaaS, multi-canal). Fonctionnalités, tarifs, automations et laquelle choisir pour vos besoins email. Anciennement Sendinblue."
    />
    <link rel="canonical" href="https://notifuse.com/fr/compare/notifuse-vs-brevo" />
    <meta name="theme-color" content="#7763F1" />
    <meta
      name="keywords"
      content="Notifuse vs Brevo, alternative Brevo, alternative Sendinblue, plateforme email auto-hébergée, email marketing open-source, tarifs Brevo"
    />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://notifuse.com/fr/compare/notifuse-vs-brevo" />
    <meta property="og:title" content="Notifuse vs Brevo : plateforme email open-source vs SaaS" />
    <meta
      property="og:description"
      content="Comparez Notifuse (open-source, Cloud ou auto-hébergé) et Brevo (SaaS, multi-canal). Toutes les fonctionnalités incluses vs tarification par palier jusqu'à 499 $/mois."
    />
    <meta property="og:image" content="https://notifuse.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Notifuse" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Notifuse vs Brevo : comparaison de plateformes email open-source" />
    <meta
      name="twitter:description"
      content="Comparez Notifuse (open-source, auto-hébergé) vs Brevo (SaaS). Toutes les fonctionnalités incluses vs 499 $/mois pour les fonctions avancées."
    />
    <meta name="twitter:image" content="https://notifuse.com/og-image.png" />
    <meta name="twitter:site" content="@notifuse" />
    <meta name="twitter:creator" content="@notifuse" />

    <GtagHead />

    <script defer data-domain="notifuse.com" src="https://plausible.notifuse.com/js/script.js"></script>

    <link rel="dns-prefetch" href="https://prod.staminads.com" />
    <link rel="preconnect" href="https://prod.staminads.com" />
    <script is:inline>
    window.StaminadsConfig = {
      workspace_id: 'notifuse',
      endpoint: 'https://prod.staminads.com'
    };
    </script>
    <script async src="/staminads_5.0.0.min.js"></script>
  </head>

  <body class="bg-white-98">
    <div class="container relative border-r border-l border-gray-200">
      <Navigation />

      <!-- Hero -->
      <section class="border-b border-gray-200">
        <div class="px-4 lg:px-8 py-20">
          <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
              <span class="bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent">Notifuse</span>
              <span class="text-slate-900"> vs Brevo</span>
            </h1>
            <p class="text-xl text-gray-600 mb-10 max-w-3xl mx-auto">
              Notifuse est open-source et auto-hébergé avec toutes les fonctionnalités incluses. Brevo (anciennement Sendinblue) est un SaaS multi-canal qui verrouille des fonctionnalités clés derrière des paliers de 18 à 499+ $/mois. Choisissez Notifuse pour la propriété totale de vos données et zéro facturation par contact.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="https://cloud.notifuse.com/signup"
                data-cta
                class="bg-primary text-white px-6 py-3 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors"
              >
                Essai gratuit 30 jours
              </a>
              <a
                href="https://demo.notifuse.com/signin?email=demo@notifuse.com"
                class="border border-gray-200 text-gray-700 px-6 py-3 rounded-md text-base font-semibold hover:bg-white transition-colors"
              >
                Démo en ligne
              </a>
            </div>
          </div>
        </div>
      </section>

      <ComparisonLayout
        title="Notifuse vs Brevo"
        description="Comparaison détaillée des fonctionnalités, tarifs et cas d'usage"
      >
        <TableOfContents slot="toc" items={tocItems} />

        <!-- Aperçu -->
        <FeatureSection id="apercu" title="Aperçu">
          <div class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl mb-12">
            <div class="bg-gradient-to-br from-orange-50 to-pink-50 rounded-xl p-12">
              <h3 class="text-xl font-bold text-slate-900 mb-8">Les deux différences fondamentales</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                  <div class="flex items-start mb-4">
                    <span class="text-2xl font-bold text-primary mr-3">1.</span>
                    <h4 class="font-semibold text-slate-900 mt-1">Open-source vs SaaS propriétaire</h4>
                  </div>
                  <p class="text-sm text-gray-700 mb-3">
                    <strong class="text-primary">Notifuse :</strong> open-source AGPL-3.0, auto-hébergé. Contrôle total sur votre code et vos données.
                  </p>
                  <p class="text-sm text-gray-500">
                    <strong>Brevo :</strong> SaaS propriétaire avec tarification par palier. Vos données sont sur les serveurs de Brevo.
                  </p>
                </div>
                <div>
                  <div class="flex items-start mb-4">
                    <span class="text-2xl font-bold text-primary mr-3">2.</span>
                    <h4 class="font-semibold text-slate-900 mt-1">Tout inclus vs verrouillé par palier</h4>
                  </div>
                  <p class="text-sm text-gray-700 mb-3">
                    <strong class="text-primary">Notifuse :</strong> toutes les fonctionnalités disponibles dès le premier jour. Pas de frais par contact.
                  </p>
                  <p class="text-sm text-gray-500">
                    <strong>Brevo :</strong> fonctionnalités clés verrouillées derrière les paliers Standard (18 $/mois), Professionnel (499 $/mois) et Entreprise.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Alerte : verrouillage des fonctionnalités -->
          <div class="bg-gradient-to-br from-gray-200 via-gray-200 to-red-400 p-px rounded-xl mb-8">
            <div class="bg-gradient-to-br from-red-50 to-orange-50 rounded-xl p-8">
              <div class="flex items-start">
                <svg class="w-8 h-8 text-red-500 mr-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
                <div>
                  <h4 class="font-bold text-slate-900 mb-2 text-lg">Le verrouillage des fonctionnalités chez Brevo</h4>
                  <p class="text-gray-700 text-sm mb-3">
                    De nombreuses fonctionnalités que vous attendriez en standard nécessitent des mises à niveau payantes chez Brevo :
                  </p>
                  <ul class="space-y-2 text-sm text-gray-700">
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                      </svg>
                      <span><strong>Standard (18 $/mois) :</strong> marketing automation, A/B testing, rapports avancés, optimisation de l'heure d'envoi</span>
                    </li>
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                      </svg>
                      <span><strong>Professionnel (499 $/mois) :</strong> WhatsApp, notifications push, scoring de contacts, segmentation IA, support téléphonique</span>
                    </li>
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                      </svg>
                      <span><strong>Entreprise (sur devis) :</strong> CDP, programmes de fidélité, objets personnalisés, IP dédiée, SSO</span>
                    </li>
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-green-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <span><strong class="text-primary">Notifuse :</strong> toutes les fonctionnalités incluses sur chaque plan Cloud dès 19 $/mois</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <p class="text-gray-600 mb-6">
            <span class="font-semibold text-slate-900">Brevo</span> (anciennement Sendinblue) est une plateforme marketing SaaS multi-canal proposant email, SMS, WhatsApp, CRM et chat en direct. Riche en fonctionnalités, elle verrouille néanmoins les capacités clés derrière des paliers coûteux et facture par contact.
          </p>
          <p class="text-gray-600 mb-6">
            <span class="font-semibold text-slate-900">Notifuse</span> est une plateforme email open-source (disponible en Cloud managé ou auto-hébergé) avec un éditeur visuel MJML, une segmentation avancée, des automations, le multi-tenancy et des connexions ESP flexibles. <strong>Toutes les fonctionnalités sont incluses</strong> dès le premier jour — pas de tarification par palier, pas de frais par contact.
          </p>
        </FeatureSection>

        <!-- Comparaison rapide -->
        <FeatureSection id="comparaison-rapide" title="Comparaison rapide" gradient>
          <ProConsTable competitor="Brevo" rows={proConsRows} />
          <div class="flex flex-col sm:flex-row gap-4 justify-center my-8">
            <a href="https://cloud.notifuse.com/signup" data-cta class="bg-primary text-white px-6 py-3 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors text-center">
              Essai gratuit 30 jours
            </a>
          </div>
        </FeatureSection>

        <!-- Tarifs & Coûts -->
        <FeatureSection id="tarifs" title="Tarifs & Coûts" gradient>
          <p class="text-gray-600 mb-6">
            Brevo verrouille les fonctionnalités clés derrière des paliers coûteux. Notifuse Cloud inclut toutes les fonctionnalités sur chaque plan, dès 19 $/mois.
          </p>

          <div class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl mb-8">
            <div class="bg-gradient-to-br from-white to-orange-50 rounded-xl p-8">
              <h4 class="font-bold text-slate-900 mb-4 text-lg text-center">Coût à l'échelle : 100K emails/mois</h4>
              <p class="text-gray-700 text-sm text-center mb-6">
                Comparez le coût réel quand vous avez besoin d'automation, d'A/B testing et de fonctionnalités avancées.
              </p>

              <div class="mb-6">
                <h5 class="text-sm font-semibold text-slate-900 text-center mb-3">Avec automations & fonctionnalités avancées</h5>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
                  <div class="border border-primary bg-orange-50 rounded-lg p-4">
                    <div class="text-xs text-gray-500 mb-1">Notifuse Cloud Pro</div>
                    <div class="text-2xl font-bold text-primary">99 $</div>
                    <div class="text-xs text-gray-600">Toutes les fonctionnalités incluses</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-4">
                    <div class="text-xs text-gray-500 mb-1">Brevo Standard</div>
                    <div class="text-2xl font-bold text-gray-700">18 $+</div>
                    <div class="text-xs text-gray-600">Automation basique uniquement</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-4">
                    <div class="text-xs text-gray-500 mb-1">Brevo Professionnel</div>
                    <div class="text-2xl font-bold text-gray-700">499 $+</div>
                    <div class="text-xs text-gray-600">Accès complet aux fonctionnalités</div>
                  </div>
                </div>
              </div>

              <div class="mb-6">
                <h5 class="text-sm font-semibold text-slate-900 text-center mb-3">Détail des plans Brevo</h5>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 text-center">
                  <div class="border border-gray-200 rounded-lg p-3">
                    <div class="text-xs font-semibold text-gray-700 mb-1">Gratuit</div>
                    <div class="text-sm text-gray-600">300 emails/jour</div>
                    <div class="text-xs text-gray-400">100K contacts</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-3">
                    <div class="text-xs font-semibold text-gray-700 mb-1">Starter 9 $/mois</div>
                    <div class="text-sm text-gray-600">5K emails/mois</div>
                    <div class="text-xs text-gray-400">Automation limitée (2K contacts)</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-3">
                    <div class="text-xs font-semibold text-gray-700 mb-1">Standard 18 $/mois</div>
                    <div class="text-sm text-gray-600">Automation illimitée + A/B</div>
                    <div class="text-xs text-gray-400">Sans WhatsApp/push</div>
                  </div>
                  <div class="border border-gray-200 rounded-lg p-3">
                    <div class="text-xs font-semibold text-gray-700 mb-1">Pro 499 $/mois</div>
                    <div class="text-sm text-gray-600">Tous les canaux</div>
                    <div class="text-xs text-gray-400">IA + scoring</div>
                  </div>
                </div>
              </div>

              <p class="text-xs text-gray-500 text-center mb-2">
                Notifuse Cloud : dès 19 $/mois (Lite) à 99 $/mois (Pro) — toutes fonctionnalités incluses, BYO-ESP
              </p>
              <p class="text-[10px] text-gray-400 text-center">
                Tarifs en vigueur en avril 2026
              </p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="border-2 border-primary rounded-xl p-8 relative overflow-hidden">
              <div class="absolute top-0 right-0 bg-primary text-white px-3 py-1 text-xs font-semibold">
                Meilleur rapport qualité-prix
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Notifuse Cloud</h3>

              <div class="space-y-2 mb-6 text-sm">
                <div class="flex justify-between items-baseline border-b border-gray-100 pb-2">
                  <span class="font-semibold text-slate-900">Lite</span>
                  <span class="text-primary font-bold">19 $/mois</span>
                </div>
                <div class="text-xs text-gray-600 -mt-1 mb-1">2 500 contacts actifs</div>
                <div class="flex justify-between items-baseline border-b border-gray-100 pb-2">
                  <span class="font-semibold text-slate-900">Starter</span>
                  <span class="text-primary font-bold">39 $/mois</span>
                </div>
                <div class="text-xs text-gray-600 -mt-1 mb-1">10 000 contacts actifs</div>
                <div class="flex justify-between items-baseline border-b border-gray-100 pb-2">
                  <span class="font-semibold text-slate-900">Pro</span>
                  <span class="text-primary font-bold">99 $/mois</span>
                </div>
                <div class="text-xs text-gray-600 -mt-1">25 000 contacts actifs</div>
              </div>

              <ul class="space-y-2 text-sm">
                <li>&#10003; Emails illimités (BYO-ESP)</li>
                <li>&#10003; Toutes les fonctionnalités sur chaque plan</li>
                <li>&#10003; Essai gratuit de 30 jours</li>
                <li>&#10003; Contacts actifs uniquement (30 derniers jours)</li>
              </ul>

              <p class="text-xs text-gray-500 mt-4">
                Ou auto-hébergement — open-source (AGPL-3.0)
              </p>
            </div>

            <div class="border border-gray-200 rounded-xl p-8">
              <h3 class="text-2xl font-bold text-slate-900 mb-2">Brevo</h3>
              <div class="text-sm text-gray-600 mb-4">Tarification SaaS par palier</div>

              <div class="space-y-3 mb-6 text-sm">
                <div>
                  <strong>Gratuit :</strong> 300 emails/jour, 100K contacts<br />
                  <span class="text-gray-500">Automation limitée (2K contacts), branding Brevo</span>
                </div>
                <div>
                  <strong>Starter :</strong> dès 9 $/mois<br />
                  <span class="text-gray-500">5K-100K emails, automation limitée (2K contacts)</span>
                </div>
                <div>
                  <strong>Standard :</strong> dès 18 $/mois<br />
                  <span class="text-gray-500">Automation, A/B testing</span>
                </div>
                <div>
                  <strong>Professionnel :</strong> dès 499 $/mois<br />
                  <span class="text-gray-500">WhatsApp, push, IA, scoring</span>
                </div>
                <div class="text-xs text-gray-500">
                  + Entreprise pour CDP, fidélité, SSO
                </div>
              </div>

              <ul class="space-y-2 text-sm text-gray-500">
                <li>&#10007; Facturation par contact à l'échelle</li>
                <li>&#10007; Fonctionnalités verrouillées par palier</li>
                <li>&#10007; Code source fermé</li>
                <li>&#10007; Cloud uniquement</li>
                <li>&#10007; Données sur les serveurs de Brevo</li>
              </ul>
            </div>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-8">
            <h4 class="font-semibold text-slate-900 mb-2">Zéro lock-in</h4>
            <p class="text-gray-700 text-sm">
              Export complet de la base de données sur demande. Notifuse est open-source (AGPL-3.0) — passez en auto-hébergement à tout moment et conservez toutes vos données.
            </p>
          </div>

          <div class="bg-gradient-to-br from-gray-50 to-orange-50 border border-gray-200 rounded-xl p-8 my-12">
            <div class="text-center max-w-2xl mx-auto">
              <h3 class="text-2xl font-bold text-slate-900 mb-3">Prêt à réduire vos coûts email ?</h3>
              <p class="text-gray-600 mb-6">Toutes les fonctionnalités dès 19 $/mois avec BYO-ESP. Pas de verrouillage par palier, pas de frais par contact.</p>
              <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="https://cloud.notifuse.com/signup" data-cta class="bg-primary text-white px-6 py-3 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors">
                  Essai gratuit 30 jours
                </a>
                <a href="https://demo.notifuse.com/signin?email=demo@notifuse.com" class="border border-gray-200 bg-white text-gray-700 px-6 py-3 rounded-md text-base font-semibold hover:bg-gray-50 transition-colors">
                  Démo en ligne
                </a>
              </div>
            </div>
          </div>
        </FeatureSection>

        <!-- Éditeur d'emails -->
        <FeatureSection id="editeur-email" title="Éditeur d'emails">
