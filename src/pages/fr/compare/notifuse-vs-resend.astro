---
import "../../../styles/global.css"
import Navigation from "../../../components/Navigation.astro"
import Footer from "../../../components/Footer.astro"
import ComparisonLayout from "../../../components/ComparisonLayout.astro"
import TableOfContents from "../../../components/TableOfContents.astro"
import ProConsTable from "../../../components/ProConsTable.astro"
import ComparisonTable from "../../../components/ComparisonTable.astro"
import FeatureSection from "../../../components/FeatureSection.astro"
import GtagHead from "../../../components/GtagHead.astro"
import CookieConsent from "../../../components/CookieConsent.astro"
import emailEditorImage from "../../../assets/screenshots/email_editor.png"
import contactProfileImage from "../../../assets/screenshots/contact_profile.png"
import dashboardImage from "../../../assets/screenshots/dashboard.png"

const tocItems = [
  { id: "apercu", label: "Aperçu" },
  { id: "comparaison-rapide", label: "Comparaison rapide" },
  { id: "editeur-email", label: "Éditeur d'emails" },
  { id: "listes-diffusion", label: "Gestion des listes" },
  { id: "campagnes", label: "Campagnes" },
  { id: "envoi-email", label: "Envoi & Délivrabilité" },
  { id: "contacts", label: "Contacts & Segmentation" },
  { id: "analytics", label: "Analytics & Reporting" },
  { id: "multi-tenant", label: "Multi-tenant & Agences" },
  { id: "api-developpeur", label: "API & Développeurs" },
  { id: "automations", label: "Automations" },
  { id: "evenements", label: "Événements personnalisés" },
  { id: "blog", label: "Blog" },
  { id: "tarifs", label: "Tarifs & Coûts" },
  { id: "cas-usage", label: "Cas d'usage" },
  { id: "pourquoi-changer", label: "Pourquoi changer" },
  { id: "faq", label: "FAQ" },
]

const proConsRows = [
  {
    label: "Prix de départ",
    notifuse: "Dès 19 $/mois (Cloud) · ou auto-hébergé",
    competitor: "Gratuit : 3 000 emails/mois",
  },
  {
    label: "Licence",
    notifuse: "Open-source (AGPL-3.0)",
    competitor: "Propriétaire (code fermé)",
  },
  {
    label: "Déploiement",
    notifuse: "Auto-hébergé",
    competitor: "Cloud uniquement (SaaS)",
  },
  {
    label: "Infrastructure",
    notifuse:
      "7 ESP (Amazon SES, Mailgun, Postmark, SendGrid, Mailjet, SparkPost) + SMTP personnalisé",
    competitor: "Amazon SES uniquement (avec marge)",
  },
  {
    label: "Éditeur visuel",
    notifuse: "MJML glisser-déposer & éditeur de code",
    competitor: "Aucun (React Email uniquement, code requis)",
  },
  {
    label: "Segmentation",
    notifuse: "Dynamique avec filtres & conditions",
    competitor: "Segments statiques uniquement",
  },
  {
    label: "Timeline de contact",
    notifuse: "Oui (historique complet d'activité)",
    competitor: "Non",
  },
]
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>Notifuse vs Resend : comparaison open-source vs propriétaire (2026)</title>
    <meta
      name="description"
      content="Comparez Notifuse et Resend pour l'envoi d'emails et les automations. Notifuse est open-source avec éditeur MJML, Resend utilise Amazon SES avec marge. Fonctionnalités, tarifs et cas d'usage."
    />
    <link rel="canonical" href="https://notifuse.com/fr/compare/notifuse-vs-resend" />
    <meta name="theme-color" content="#7763F1" />
    <meta
      name="keywords"
      content="Notifuse vs Resend, alternative Resend, plateforme email open-source, éditeur MJML, Amazon SES, React Email, comparaison API email"
    />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://notifuse.com/fr/compare/notifuse-vs-resend" />
    <meta property="og:title" content="Notifuse vs Resend : comparaison open-source vs propriétaire" />
    <meta
      property="og:description"
      content="Comparez Notifuse (open-source, auto-hébergé) et Resend (propriétaire, wrapper Amazon SES). Fonctionnalités, tarifs et quelle plateforme choisir."
    />
    <meta property="og:image" content="https://notifuse.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Notifuse" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Notifuse vs Resend : comparaison de plateformes email open-source" />
    <meta
      name="twitter:description"
      content="Comparez Notifuse (open-source) vs Resend (wrapper Amazon SES). Éditeur MJML auto-hébergé vs React Email cloud."
    />
    <meta name="twitter:image" content="https://notifuse.com/og-image.png" />
    <meta name="twitter:site" content="@notifuse" />
    <meta name="twitter:creator" content="@notifuse" />

    <GtagHead />

    <script defer data-domain="notifuse.com" src="https://plausible.notifuse.com/js/script.js"></script>

    <link rel="dns-prefetch" href="https://prod.staminads.com" />
    <link rel="preconnect" href="https://prod.staminads.com" />
    <script is:inline>
    window.StaminadsConfig = {
      workspace_id: 'notifuse',
      endpoint: 'https://prod.staminads.com'
    };
    </script>
    <script async src="/staminads_5.0.0.min.js"></script>
  </head>

  <body class="bg-white-98">
    <div class="container relative border-r border-l border-gray-200">
      <Navigation />

      <!-- Hero -->
      <section class="border-b border-gray-200">
        <div class="px-4 lg:px-8 py-20">
          <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
              <span class="bg-gradient-to-r from-primary to-pink-600 bg-clip-text text-transparent">Notifuse</span>
              <span class="text-slate-900"> vs Resend</span>
            </h1>
            <p class="text-xl text-gray-600 mb-10 max-w-3xl mx-auto">
              Notifuse est open-source avec un éditeur visuel MJML. Resend est un wrapper propriétaire autour d'Amazon SES avec React Email (code requis). Choisissez Notifuse pour éviter le vendor lock-in et les limitations d'un seul fournisseur.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="https://cloud.notifuse.com/signup"
                data-cta
                class="bg-primary text-white px-6 py-3 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors"
              >
                Essai gratuit 30 jours
              </a>
              <a
                href="https://demo.notifuse.com/signin?email=demo@notifuse.com"
                class="border border-gray-200 text-gray-700 px-6 py-3 rounded-md text-base font-semibold hover:bg-white transition-colors"
              >
                Démo en ligne
              </a>
            </div>
          </div>
        </div>
      </section>

      <ComparisonLayout
        title="Notifuse vs Resend"
        description="Comparaison détaillée des fonctionnalités, tarifs et cas d'usage"
      >
        <TableOfContents slot="toc" items={tocItems} />

        <!-- Aperçu -->
        <FeatureSection id="apercu" title="Aperçu">
          <div class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl mb-12">
            <div class="bg-gradient-to-br from-orange-50 to-pink-50 rounded-xl p-12">
              <h3 class="text-xl font-bold text-slate-900 mb-8">Deux différences fondamentales</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                  <div class="flex items-start mb-4">
                    <span class="text-2xl font-bold text-primary mr-3">1.</span>
                    <h4 class="font-semibold text-slate-900 mt-1">Open-source vs Code fermé</h4>
                  </div>
                  <p class="text-sm text-gray-700 mb-3">
                    <strong class="text-primary">Notifuse :</strong> AGPL-3.0 open-source, auto-hébergé. Contrôle total sur votre code et vos données.
                  </p>
                  <p class="text-sm text-gray-500">
                    <strong>Resend :</strong> SaaS propriétaire à code fermé. Vendor lock-in sans accès au code.
                  </p>
                </div>
                <div>
                  <div class="flex items-start mb-4">
                    <span class="text-2xl font-bold text-primary mr-3">2.</span>
                    <h4 class="font-semibold text-slate-900 mt-1">Éditeur visuel vs Code uniquement</h4>
                  </div>
                  <p class="text-sm text-gray-700 mb-3">
                    <strong class="text-primary">Notifuse :</strong> éditeur visuel MJML glisser-déposer. Aucun code requis.
                  </p>
                  <p class="text-sm text-gray-500">
                    <strong>Resend :</strong> React Email uniquement. Chaque template doit être codé.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Alerte : Amazon SES -->
          <div class="bg-gradient-to-br from-gray-200 via-gray-200 to-red-400 p-px rounded-xl mb-8">
            <div class="bg-gradient-to-br from-red-50 to-orange-50 rounded-xl p-8">
              <div class="flex items-start">
                <svg class="w-8 h-8 text-red-500 mr-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
                <div>
                  <h4 class="font-bold text-slate-900 mb-2 text-lg">Resend utilise Amazon SES en coulisses</h4>
                  <p class="text-gray-700 text-sm mb-3">
                    Resend repose sur Amazon SES et applique une marge tarifaire. Avec Notifuse, vous pouvez :
                  </p>
                  <ul class="space-y-2 text-sm text-gray-700">
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-green-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <span>Vous connecter <strong>directement à Amazon SES</strong> (même infrastructure, sans marge)</span>
                    </li>
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-green-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <span><strong>Ne pas dépendre d'un seul ESP :</strong> utilisez Amazon SES, Mailgun, Postmark ou n'importe quel serveur SMTP</span>
                    </li>
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-green-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <span><strong>Configurer vos propres limites d'envoi</strong> (impossible avec Resend)</span>
                    </li>
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-green-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                      </svg>
                      <span>Payer <strong>uniquement les coûts AWS</strong> (~1 $ pour 10 000 emails)</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <p class="text-gray-600 mb-6">
            <span class="font-semibold text-slate-900">Resend</span> est une API email cloud orientée développeurs, construite sur Amazon SES. Elle mise sur la simplicité avec des templates React Email, mais reste propriétaire, cloud uniquement, et applique une marge sur l'infrastructure Amazon SES.
          </p>
          <p class="text-gray-600 mb-6">
            <span class="font-semibold text-slate-900">Notifuse</span> est une plateforme email open-source (disponible en Cloud managé ou auto-hébergé) avec un éditeur visuel MJML, une segmentation avancée, le multi-tenancy et des connexions ESP flexibles. <strong>Pas de dépendance à un seul fournisseur</strong> : utilisez Amazon SES, Mailgun, Postmark, SendGrid, ou combinez différents ESP pour vos emails transactionnels et marketing.
          </p>
        </FeatureSection>

        <!-- Comparaison rapide -->
        <FeatureSection id="comparaison-rapide" title="Comparaison rapide" gradient>
          <ProConsTable competitor="Resend" rows={proConsRows} />
          <div class="flex flex-col sm:flex-row gap-4 justify-center my-8">
            <a href="https://cloud.notifuse.com/signup" data-cta class="bg-primary text-white px-6 py-3 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors text-center">
              Essai gratuit 30 jours
            </a>
          </div>
        </FeatureSection>

        <!-- Éditeur d'emails -->
        <FeatureSection id="editeur-email" title="Éditeur d'emails">
          <p class="text-gray-600 mb-6">
            La différence majeure : Notifuse propose un éditeur visuel no-code, tandis que Resend exige de coder chaque template email en React.
          </p>

          <ComparisonTable
            title="Comparaison des éditeurs"
            competitorName="Resend"
            features={[
              {
                feature: "Éditeur visuel",
                notifuse:
                  '<a href="https://documentation.mjml.io/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline font-semibold">MJML</a> — glisser-déposer & éditeur de code, rendu mobile-responsive garanti sur tous les clients email',
                competitor: "Aucun — React Email nécessite du code",
              },
              {
                feature: "Moteur de templates",
                notifuse:
                  '<a href="https://shopify.github.io/liquid/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline font-semibold">Liquid</a>',
                competitor: "React/JSX",
                description: "Variables dynamiques pour la personnalisation",
              },
              {
                feature: "Gestionnaire de fichiers",
                notifuse: "Stockage S3 avec CDN intégré",
                competitor: false,
              },
              {
                feature: "Bibliothèque de templates",
                notifuse: "Bientôt disponible",
                competitor: "Templates React Email",
              },
              {
                feature: "Éditeur de code MJML",
                notifuse: "Édition directe du code MJML en parallèle du visuel",
                competitor: false,
                description: "Basculez entre les modes visuel et code",
              },
              {
                feature: "Données de test",
                notifuse: true,
                competitor: false,
                description: "Prévisualisez vos emails avec des données de contact fictives",
              },
            ]}
          />

          <div class="my-8">
            <div class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl">
              <div class="rounded-xl overflow-hidden">
                <img src={emailEditorImage.src} alt="Éditeur email MJML de Notifuse" class="w-full h-auto" />
              </div>
            </div>
            <p class="text-center text-xs text-gray-500 mt-2">Interface Notifuse — Éditeur visuel MJML (aucun code requis)</p>
          </div>

          <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 my-6">
            <h4 class="font-semibold text-slate-900 mb-2">Pourquoi c'est important</h4>
            <p class="text-gray-700 text-sm">
              Avec Notifuse, les membres non techniques de votre équipe peuvent créer des emails grâce à l'éditeur visuel MJML. Resend exige que les développeurs codent chaque template en React, ce qui le rend inadapté aux équipes avec des marketeurs ou du personnel non technique.
            </p>
          </div>
        </FeatureSection>

        <!-- Gestion des listes -->
        <FeatureSection id="listes-diffusion" title="Gestion des listes de diffusion">
          <p class="text-gray-600 mb-6">
            Les deux plateformes gèrent les audiences, mais avec des fonctionnalités différentes. Note : Resend appelle les listes de diffusion « Topics ».
          </p>

          <ComparisonTable
            title="Fonctionnalités de gestion de listes"
            competitorName="Resend"
            features={[
              {
                feature: "Listes de diffusion",
                notifuse: "Listes complètes avec toutes les fonctionnalités",
                competitor: "Topics (terminologie Resend)",
              },
              {
                feature: "Listes privées",
                notifuse: true,
                competitor: true,
              },
              {
                feature: "Double opt-in",
                notifuse: true,
                competitor: false,
              },
              {
                feature: "Email de bienvenue",
                notifuse: true,
                competitor: false,
              },
              {
                feature: "Email de désinscription",
                notifuse: true,
                competitor: false,
              },
              {
                feature: "Analytics de liste",
                notifuse: true,
                competitor: false,
                description: "Métriques : actifs, désinscrits, spam, plaintes",
              },
              {
                feature: "Centre de notifications",
                notifuse: true,
                competitor: false,
                description: "Centre de gestion des préférences en libre-service pour les abonnés",
              },
            ]}
          />
        </FeatureSection>

        <!-- Campagnes -->
        <FeatureSection id="campagnes" title="Campagnes">
          <p class="text-gray-600 mb-6">
            Les deux plateformes permettent d'envoyer des campagnes broadcast, mais Notifuse propose bien plus de fonctionnalités.
          </p>

          <ComparisonTable
            title="Fonctionnalités de campagne"
            competitorName="Resend"
            features={[
              {
                feature: "Campagnes broadcast",
                notifuse: true,
                competitor: true,
              },
              {
                feature: "Envoi vers plusieurs listes",
                notifuse: true,
                competitor: true,
              },
              {
                feature: "Filtrage par segments",
                notifuse: true,
                competitor: false,
                description: "Les segments Resend sont des groupes statiques sans filtres",
              },
              {
                feature: "A/B Testing avec sélection auto du gagnant",
                notifuse: true,
                competitor: false,
              },
              {
                feature: "Paramètres UTM",
                notifuse: true,
                competitor: false,
              },
              {
                feature: "Planification par fuseau horaire",
                notifuse: true,
                competitor: false,
              },
              {
                feature: "Data Feed global",
                notifuse: "Un seul appel API, données partagées entre tous les destinataires",
                competitor: false,
              },
              {
                feature: "Data Feed par destinataire",
                notifuse: "Appels API individuels avec données spécifiques par contact",
                competitor: false,
                description: "Personnalisez vos emails avec des données en temps réel (recommandations produit, prix, stock)",
              },
            ]}
          />
        </FeatureSection>

        <!-- Contacts & Segmentation -->
        <FeatureSection id="contacts" title="Contacts & Segmentation">
          <p class="text-gray-600 mb-6">
            Différence majeure : Notifuse dispose de timelines d'activité complètes et de segments dynamiques, tandis que Resend ne propose que des segments statiques et aucune timeline d'activité.
          </p>

          <ComparisonTable
            title="Fonctionnalités contacts & segmentation"
            competitorName="Resend"
            features={[
              {
                feature: "Champs personnalisés",
                notifuse: true,
                competitor: true,
              },
              {
                feature: "Timeline d'activité",
                notifuse: true,
                competitor: false,
                description: "Historique complet des emails, ouvertures, clics et modifications de profil",
              },
              {
                feature: "Type de segmentation",
                notifuse: "Dynamique avec filtres & conditions",
                competitor: "Segments statiques uniquement (aucune règle dynamique)",
              },
              {
                feature: "Filtres par dates relatives",
                notifuse: true,
                competitor: false,
                description: 'Ex. « inscrit dans les 30 derniers jours »',
              },
            ]}
          />

          <div class="my-8">
            <div class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl">
              <div class="rounded-xl overflow-hidden">
                <img src={contactProfileImage.src} alt="Profil contact Notifuse avec timeline d'activité" class="w-full h-auto" />
              </div>
            </div>
            <p class="text-center text-xs text-gray-500 mt-2">Interface Notifuse — Profil contact avec timeline (Resend n'a pas cette fonctionnalité)</p>
          </div>

          <div class="bg-purple-50 border border-purple-200 rounded-lg p-6 my-6">
            <h4 class="font-semibold text-slate-900 mb-2">Segmentation dynamique vs statique</h4>
            <p class="text-gray-700 text-sm">
              Les segments dynamiques de Notifuse se mettent à jour automatiquement selon les conditions et filtres définis. Les segments de Resend sont de simples groupes statiques : vous ajoutez/retirez manuellement les contacts. Impossible de créer des segments « utilisateurs actifs ces 30 derniers jours » ou « ont ouvert sans cliquer » avec Resend.
            </p>
          </div>
        </FeatureSection>

        <!-- Envoi & Délivrabilité -->
        <FeatureSection id="envoi-email" title="Envoi & Délivrabilité">
          <div class="bg-gradient-to-br from-gray-200 via-gray-200 to-green-400 p-px rounded-xl mb-8">
            <div class="bg-gradient-to-br from-white to-green-50 rounded-xl p-8">
              <h4 class="font-bold text-slate-900 mb-3 text-lg">Flexibilité ESP : un avantage majeur</h4>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <p class="text-sm font-semibold text-primary mb-2">Notifuse</p>
                  <ul class="text-sm text-gray-700 space-y-1">
                    <li>✓ Choix de l'ESP (Amazon SES, Mailgun, Postmark, SendGrid, Mailjet, SparkPost) + SMTP personnalisé</li>
                    <li>✓ ESP différent pour transactionnel vs marketing</li>
                    <li>✓ Changez d'ESP à tout moment</li>
                    <li>✓ Configurez vos limites d'envoi</li>
                    <li>✓ Aucun vendor lock-in</li>
                  </ul>
                </div>
                <div>
                  <p class="text-sm font-semibold text-gray-700 mb-2">Resend</p>
                  <ul class="text-sm text-gray-500 space-y-1">
                    <li>✗ Verrouillé sur Amazon SES uniquement</li>
                    <li>✗ Impossible d'utiliser d'autres ESP</li>
                    <li>✗ Impossible de changer de fournisseur</li>
                    <li>✗ Impossible de configurer les limites d'envoi</li>
                    <li>✗ Vendor lock-in</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <ComparisonTable
            title="Fonctionnalités d'envoi"
            competitorName="Resend"
            features={[
              {
                feature: "Options ESP",
