---
import "../../styles/global.css"
import emailBuilderImage from "../../assets/screenshots/email_editor.png"
import emailBuilderZoomImage from "../../assets/screenshots/email_builder_zoom.png"
import IntegrationMarquee from "../../components/IntegrationMarquee.astro"
import Navigation from "../../components/Navigation.astro"
import Footer from "../../components/Footer.astro"
import FileManagerPreview from "../../components/FileManagerPreview.astro"
import ContactProfilePreview from "../../components/ContactProfilePreview.astro"
import AnalyticsPreview from "../../components/AnalyticsPreview.astro"
import ABTestingPreview from "../../components/ABTestingPreview.astro"
import TransactionalAPIPreview from "../../components/TransactionalAPIPreview.astro"
import NotificationCenterPreview from "../../components/NotificationCenterPreview.astro"
import SegmentationEnginePreview from "../../components/SegmentationEnginePreview.astro"
import PermissionsPreview from "../../components/PermissionsPreview.astro"
import WorkspacesPreview from "../../components/WorkspacesPreview.astro"
import AutomationsPreview from "../../components/AutomationsPreview.astro"
import GtagHead from "../../components/GtagHead.astro"
import CookieConsent from "../../components/CookieConsent.astro"
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Notifuse - Alternative open-source gratuite à Mailchimp et Resend</title>
    <meta
      name="description"
      content="Plateforme d'emailing open-source pour newsletters et emails transactionnels. Alternative auto-hébergée à Mailchimp, Resend et Loops.so avec éditeur visuel MJML, tests A/B et analytics."
    />

    <!-- SEO Meta Tags -->
    <link rel="canonical" href="https://notifuse.com/fr/" />
    <meta name="theme-color" content="#7763F1" />
    <meta name="author" content="Notifuse" />
    <meta
      name="keywords"
      content="plateforme email open source, logiciel newsletter, alternative mailchimp, email auto-hébergé, email transactionnel, éditeur MJML, email marketing, alternative resend"
    />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://notifuse.com/fr/" />
    <meta
      property="og:title"
      content="Notifuse - Alternative open-source gratuite à Mailchimp et Resend"
    />
    <meta
      property="og:description"
      content="Plateforme d'emailing open-source pour newsletters et emails transactionnels. Alternative auto-hébergée à Mailchimp, Resend et Loops.so avec éditeur visuel MJML, tests A/B et analytics."
    />
    <meta property="og:image" content="https://notifuse.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Notifuse" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Notifuse - Alternative open-source gratuite à Mailchimp et Resend"
    />
    <meta
      name="twitter:description"
      content="Plateforme d'emailing open-source pour newsletters et emails transactionnels. Alternative auto-hébergée à Mailchimp, Resend et Loops.so avec éditeur visuel MJML, tests A/B et analytics."
    />
    <meta name="twitter:image" content="https://notifuse.com/og-image.png" />
    <meta name="twitter:site" content="@notifuse" />
    <meta name="twitter:creator" content="@notifuse" />

    <!-- Additional Links -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <GtagHead />
    <script
      defer
      data-domain="notifuse.com"
      src="https://plausible.notifuse.com/js/script.js"></script>

    <!-- Staminads Analytics -->
    <link rel="dns-prefetch" href="https://prod.staminads.com" />
    <link rel="preconnect" href="https://prod.staminads.com" />
    <script is:inline>
    window.StaminadsConfig = {
      workspace_id: 'notifuse',
      endpoint: 'https://prod.staminads.com'
    };
    </script>
    <script async src="/staminads_5.0.0.min.js"></script>
  </head>
  <body class="bg-white-98">
    <div class="container relative border-r border-l border-gray-200">
      <!-- Navigation -->
      <Navigation />

      <!-- Hero Section -->
      <section>
        <div class="px-4 lg:px-8 py-20">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Content -->
            <div class="text-center lg:text-left">
              <h1 class="text-2xl lg:text-3xl font-bold text-slate-900 mb-6">
                L'<span class="italic text-primary"
                  >alternative</span
                > open-source à :<br />
                <span class="text-sm lg:text-lg text-gray-600 font-normal"
                  >Mailchimp, Brevo, Mailjet, Listmonk, Mailerlite, Klaviyo...</span
                >
              </h1>
              <p class="text-lg text-black mb-10 max-w-3xl lg:max-w-none">
                Notifuse est une plateforme d'emailing moderne et auto-hébergée
                qui vous permet d'envoyer des newsletters et des emails
                transactionnels à moindre coût.
              </p>
              <div
                class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start"
              >
                <a
                  href="https://demo.notifuse.com/console/signin?email=demo@notifuse.com"
                  class="bg-primary text-white px-4 py-2 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors"
                >
                  Démo en ligne
                </a>
                <a
                  href="https://cloud.notifuse.com/signup"
                  class="border border-gray-200 text-gray-700 px-4 py-2 rounded-md text-base font-semibold hover:bg-white transition-colors"
                >
                  S'inscrire gratuitement
                </a>
              </div>
            </div>

            <!-- App Preview -->
            <div
              class="relative max-w-md mx-auto lg:max-w-md lg:ml-auto lg:mr-0"
            >
              <div class="relative">
                <img
                  src={emailBuilderImage.src}
                  alt="Aperçu du tableau de bord Notifuse"
                  class="w-full rounded-xl shadow-xl shadow-primary/25 border border-gray-200"
                />
              </div>
            </div>
          </div>

          <!-- Integration Logos - Streaming -->
          <IntegrationMarquee />
        </div>
      </section>

      <!-- Features Bento Grid -->
      <section class="border-t border-gray-200" id="features">
        <div class="py-20">
          <div class="px-4 lg:px-8 text-center mb-16">
            <h2 class="text-3xl font-bold text-slate-900 mb-4">
              Tout ce dont vous avez besoin pour réussir
            </h2>
            <p class="text-xl text-gray-600 mx-auto">
              Des fonctionnalités puissantes conçues pour vous aider à créer,
              envoyer et suivre vos newsletters facilement.
            </p>
          </div>

          <!-- Bento Grid -->
          <div
            class="grid grid-cols-1 md:grid-cols-3 border-t border-gray-200 overflow-hidden"
          >
            <!-- Row 1: 2 Big Blocks -->
            <!-- Visual Email Builder -->
            <div
              class="md:col-span-2 p-8 border-r border-b border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-6">
                <h3 class="text-lg font-bold text-slate-900">
                  Éditeur d'emails visuel
                </h3>
              </div>
              <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class="flex-1">
                  <p class="text-gray-600 text-sm mb-4">
                    Créez de superbes emails avec notre éditeur intuitif en
                    glisser-déposer. Construisez des mises en page responsives
                    avec des composants <span
                      class="text-primary font-semibold">MJML</span
                    > et un aperçu en temps réel.
                  </p>
                  <p class="text-gray-600 text-sm mb-6">
                    Personnalisez vos emails avec les variables de template <span
                      class="text-primary font-semibold">Liquid</span
                    > comme <span
                      class="px-1.5 py-0.5 bg-orange-100 rounded font-mono text-xs"
                      >{`{{ contact.first_name }}`}</span
                    > et des champs personnalisés pour du contenu dynamique.
                  </p>
                </div>
                <div
                  class="bg-gradient-to-br from-gray-200 via-gray-200 to-primary/80 p-px rounded-xl w-full md:max-w-72 md:flex-shrink-0"
                >
                  <div class="rounded-xl overflow-hidden bg-white">
                    <img
                      src={emailBuilderZoomImage.src}
                      alt="Interface de l'éditeur d'emails"
                      class="w-full h-auto opacity-65"
                    />
                  </div>
                </div>
              </div>
            </div>

            <!-- S3 File Manager -->
            <div
              class="md:col-span-1 p-8 border-b border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">
                  Gestionnaire de fichiers S3
                </h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                Gestion intégrée des fichiers avec stockage compatible <span
                  class="text-primary font-semibold">S3</span
                > pour les images, les pièces jointes et la diffusion via <span
                  class="text-primary font-semibold">CDN</span
                >.
              </p>
              <FileManagerPreview />
            </div>

            <!-- Row 2: 3 Small Blocks -->
            <!-- Contact Profiles & Activity Timeline -->
            <div
              class="md:col-span-1 md:row-span-2 p-8 border-r border-b border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">
                  Profils contacts et historique
                </h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                Profils de contacts enrichis avec champs personnalisés et
                historique complet des activités incluant les messages, les
                modifications de profil, les événements webhook et les
                changements de listes d'abonnement.
              </p>
              <ContactProfilePreview />
            </div>

            <!-- Transactional API & MJML -->
            <div
              class="md:col-span-2 p-8 border-b border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">
                  API transactionnelle
                </h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                API REST puissante pour les emails transactionnels avec des
                templates responsives pour un rendu parfait sur tous les
                appareils.
              </p>
              <TransactionalAPIPreview />
            </div>

            <!-- Row 3: Opens & Click Tracking -->
            <!-- Opens & Click Tracking -->
            <div
              class="md:col-span-1 p-8 border-r border-b border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">
                  Suivi des ouvertures et clics
                </h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                Analytiques en temps réel avec taux d'ouverture détaillés, suivi
                des clics et métriques d'engagement pour optimiser vos
                campagnes.
              </p>
              <AnalyticsPreview />
            </div>

            <!-- Notification Center -->
            <div
              class="md:col-span-1 p-8 border-r border-b border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">
                  Centre de notifications
                </h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                Portail en libre-service permettant aux contacts de gérer leurs
                abonnements, préférences et paramètres de communication.
              </p>
              <NotificationCenterPreview />
            </div>

            <!-- A/B Testing -->
            <div
              class="md:col-span-1 p-8 border-b border-r border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">
                  Tests A/B
                </h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                Optimisez vos newsletters grâce aux tests A/B intégrés pour les
                objets, le contenu et les horaires d'envoi.
              </p>
              <ABTestingPreview />
            </div>

            <!-- Row 4: Segmentation Engine -->
            <!-- Real-time Segmentation -->
            <div
              class="md:col-span-1 p-8 border-b border-r border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">
                  Segmentation en temps réel
                </h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                Segmentez vos contacts par propriété, activité et abonnement.
                Créez des règles dynamiques avec des dates relatives pour des
                campagnes ciblées.
              </p>
              <SegmentationEnginePreview />
            </div>

            <!-- Row 5: Permissions + Workspaces + Automations -->
            <!-- User Permissions -->
            <div
              class="md:col-span-1 p-8 border-b border-r border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">
                  Gestion des permissions
                </h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                Contrôle d'accès granulaire au niveau des workspaces avec
                plusieurs rôles. Idéal pour la collaboration en équipe et la
                sécurité.
              </p>
              <PermissionsPreview />
            </div>

            <!-- Workspaces -->
            <div
              class="md:col-span-1 p-8 border-b border-r border-gray-200 hover:bg-white transition-colors"
            >
              <div class="mb-4">
                <h3 class="text-lg font-semibold text-slate-900">Workspaces</h3>
              </div>
              <p class="text-gray-600 text-sm mb-6">
                Architecture multi-tenant avec domaines personnalisés. Chaque
                workspace dispose de données, contacts et campagnes isolés.
                Idéal pour les agences.
              </p>
              <WorkspacesPreview />
            </div>

            <!-- Automations -->
            <div
              class="md:col-span-2 p-8 border-b border-gray-200 hover:bg-white transition-colors"
            >
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Left Column: Title and Description -->
                <div class="flex flex-col justify-center md:order-1">
                  <div class="mb-4">
                    <h3 class="text-lg font-semibold text-slate-900">
                      Automatisations
                    </h3>
                  </div>
                  <p class="text-gray-600 text-sm mb-3">
                    Workflows déclenchés par événements, basés sur la timeline
                    des contacts. Créez des séquences automatisées selon le
                    comportement et les actions des abonnés.
                  </p>
                  <p class="text-gray-600 text-sm mb-3">
                    Déclenchez des emails, des délais d'attente, des conditions
                    et des tests A/B dans des flux multi-étapes. Idéal pour les
                    séries de bienvenue, l'onboarding et les campagnes de
                    réengagement.
                  </p>
                  <p class="text-gray-600 text-sm">
                    Concevez des parcours complexes avec le constructeur visuel
                    de workflows et l'exécution automatique.
                  </p>
                </div>

                <!-- Right Column: Illustration -->
                <div class="md:order-2">
                  <AutomationsPreview />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Support Section -->
      <section class="border-t border-gray-200">
        <div class="px-4 lg:px-8 py-20">
          <div class="text-center max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-slate-900 mb-4">
              Le support client est toujours là pour vous aider
            </h2>
            <p class="text-xl text-gray-600 mb-12">
              Que vous utilisiez l'auto-hébergement ou Notifuse Cloud, nous
              sommes là pour vous.
            </p>
            <div
              class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-2xl mx-auto"
            >
              <div class="text-center">
                <h3 class="font-semibold text-slate-900 mb-2">
                  Notifuse Cloud
                </h3>
                <p class="text-gray-600 text-sm mb-4">
                  Support email prioritaire sur tous les plans payants.
                </p>
                <a
                  href="/pricing"
                  class="inline-block bg-primary text-white px-6 py-2.5 rounded-md font-semibold hover:bg-primary/90 transition-colors"
                >
                  Voir les tarifs
                </a>
              </div>
              <div class="text-center">
                <h3 class="font-semibold text-slate-900 mb-2">Auto-hébergé</h3>
                <p class="text-gray-600 text-sm mb-4">
                  Support communautaire via GitHub Issues.
                </p>
                <a
                  href="https://github.com/notifuse/notifuse/issues"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block border border-gray-300 text-slate-900 px-6 py-2.5 rounded-md font-semibold hover:bg-gray-50 transition-colors"
                >
                  Ouvrir un ticket
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Newsletter Subscribe Section -->
      <section class="bg-gray-900 text-white border-t border-gray-200">
        <div class="px-4 lg:px-8 py-20 text-center">
          <h2 class="text-2xl font-bold mb-4">
            Restez informé avec <span class="italic text-primary">Notifuse</span>
          </h2>
          <p class="text-lg text-gray-300 mb-8 max-w-3xl mx-auto">
            Recevez les dernières mises à jour, annonces de fonctionnalités et
            conseils pour créer de meilleures newsletters. Rejoignez notre
            communauté de développeurs et marketeurs.
          </p>
          <div class="max-w-md mx-auto">
            <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3">
              <input
                id="email-input"
                type="email"
                placeholder="Votre adresse email"
                class="flex-1 px-3 py-2 rounded-md bg-gray-800 border border-gray-700 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                required
              />
              <button
                id="subscribe-btn"
                type="submit"
                class="bg-primary text-white px-4 py-2 rounded-md text-base font-semibold hover:bg-primary/80 transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
              >
                S'abonner
              </button>
            </form>
            <div id="form-message" class="mt-3 text-sm"></div>
            <p class="text-sm text-gray-400 mt-3">
              Pas de spam, désinscription à tout moment.
            </p>
          </div>
        </div>
      </section>
      <!-- Footer -->
      <Footer />
    </div>

    <CookieConsent />
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById(
          "newsletter-form"
        ) as HTMLFormElement
        const emailInput = document.getElementById(
          "email-input"
        ) as HTMLInputElement
        const submitBtn = document.getElementById(
          "subscribe-btn"
        ) as HTMLButtonElement
        const messageDiv = document.getElementById(
          "form-message"
        ) as HTMLDivElement

        function showMessage(message: string, isError: boolean = false): void {
          if (messageDiv) {
            messageDiv.textContent = message
            messageDiv.className = `mt-3 text-sm ${isError ? "text-red-400" : "text-green-400"}`
          }
        }

        function setLoading(loading: boolean): void {
          if (submitBtn) {
            submitBtn.disabled = loading
            submitBtn.textContent = loading ? "Inscription..." : "S'abonner"
          }
        }

        if (form && emailInput && submitBtn && messageDiv) {
          form.addEventListener("submit", async function (e) {
            e.preventDefault()

            const email = emailInput.value.trim()
            if (!email) {
              showMessage("Veuillez entrer une adresse email valide.", true)
              return
            }

            setLoading(true)
            messageDiv.textContent = ""

            try {
              const response = await fetch(
                "https://v3.notifuse.com/subscribe",
                {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                  },
                  body: JSON.stringify({
                    workspace_id: "notifuse",
                    contact: {
                      email: email,
                    },
                    list_ids: ["newsletter"],
                  }),
                }
              )

              if (response.ok) {
                const data = await response.json()
                if (data.success) {
                  showMessage(
                    "Inscription réussie ! Vérifiez votre email pour confirmer."
                  )
                  emailInput.value = ""
                } else {
                  showMessage("L'inscription a échoué. Veuillez réessayer.", true)
                }
              } else {
                const errorData = await response.json().catch(() => ({}))
                const errorMessage =
                  errorData.message || "L'inscription a échoué. Veuillez réessayer."
                showMessage(errorMessage, true)
              }
            } catch (error) {
              console.error("Subscription error:", error)
              showMessage(
                "Erreur réseau. Veuillez vérifier votre connexion et réessayer.",
                true
              )
            } finally {
              setLoading(false)
            }
          })
        }
      })
    </script>
  </body>
</html>
